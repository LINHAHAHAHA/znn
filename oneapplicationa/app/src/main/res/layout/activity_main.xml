<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="公安接处警平台"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:gravity="center"
            android:paddingVertical="16dp" />

        <!-- 语音录音区域 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📞 语音接警"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:paddingBottom="12dp" />

                <Button
                    android:id="@+id/btnStartRecord"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="开始录音"
                    android:textSize="16sp"
                    android:backgroundTint="@color/primary" />

                <TextView
                    android:id="@+id/tvRecordStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="点击开始录音按钮"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center"
                    android:paddingTop="8dp" />

                <EditText
                    android:id="@+id/etVoiceText"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="语音转文字内容将显示在这里..."
                    android:gravity="top|start"
                    android:padding="12dp"
                    android:background="@drawable/edit_text_background"
                    android:layout_marginTop="12dp"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnAnalyze"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🤖 AI智能分析"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/accent" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI分析结果 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎯 AI分析结果"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/tvIncidentType"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="警情类型: 待分析"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvUrgencyLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="紧急程度: 待分析"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 接警单信息 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📝 接警单信息"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:paddingBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="报警人电话"
                    android:textSize="12sp"
                    android:textColor="#666666" />

                <EditText
                    android:id="@+id/etCallerPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="请输入报警人电话"
                    android:inputType="phone"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="报警人姓名"
                    android:textSize="12sp"
                    android:textColor="#666666" />

                <EditText
                    android:id="@+id/etCallerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="请输入报警人姓名"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="事发地点 *"
                    android:textSize="12sp"
                    android:textColor="#666666" />

                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="AI自动提取或手动输入"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="事发时间"
                    android:textSize="12sp"
                    android:textColor="#666666" />

                <EditText
                    android:id="@+id/etIncidentTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="AI自动提取或手动输入"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="涉及人员"
                    android:textSize="12sp"
                    android:textColor="#666666" />

                <EditText
                    android:id="@+id/etInvolvedPersons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="AI自动提取或手动输入"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="事件描述"
                    android:textSize="12sp"
                    android:textColor="#666666" />

                <EditText
                    android:id="@+id/etIncidentDescription"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:hint="AI自动提取或手动输入"
                    android:gravity="top|start"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="处置预案建议"
                    android:textSize="12sp"
                    android:textColor="#666666" />

                <EditText
                    android:id="@+id/etSuggestedAction"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:hint="AI推荐的处置预案"
                    android:gravity="top|start"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💾 保存接警单"
                android:textSize="16sp"
                android:backgroundTint="@color/green"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🗑️ 清空"
                android:textSize="16sp"
                android:backgroundTint="@color/gray" />
        </LinearLayout>

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 查看历史记录"
            android:textSize="16sp"
            android:backgroundTint="@color/primary" />

    </LinearLayout>
</ScrollView>

